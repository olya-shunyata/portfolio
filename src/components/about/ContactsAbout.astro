---
import DownloadIcon from "../icons/DownloadIcon.astro";

const title = "Let's get in touch!";
const links = [
  { label: "Telegram", href: "#" },
  { label: "LinkedIn", href: "#" },
  { label: "CV", href: "#", icon: DownloadIcon },
]

const email = "olgabis.design@gmail.com";

---
<div class="contacts">
  <h2 class="contacts__title">{title}</h2>
  <div class="contacts__list">
    {links.map((link) => (
      <div class="contacts__point">
        <a href={link.href} class="contacts__plaque">
          {link.icon && <link.icon size="15" class="contacts__link-icon" />}
          {link.label}
        </a>
      </div>
    ))}
  </div>
  <span class="contacts__mail">
    {email}
  </span>
</div>

<style lang="scss">
.contacts {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.contacts__title {
  margin-bottom: 4px;
  font-size: 34px;
  line-height: 1.15;
}

.contacts__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4l);
  min-width: 0;
  padding: var(--space-4l) var(--space-6l) var(--container-padding) var(--space-6l);
}

.contacts__list {
  display: flex;
  gap: 8px;
}

.contacts__plaque {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  
  min-width: 104px;
  max-width: 100%;
  padding: 10px 20px;
  border: 1px solid rgba(15, 15, 15, 0.7);
  
  font-size: 16px;
  line-height: 1.3;
  color: var(--color-text);
  text-decoration: none;
  white-space: nowrap;
  
  transition: all 0.2s ease-in-out;
  cursor: pointer;

  &:hover {
    background-color: var(--color-accent);
    border-color: var(--color-dark);
  }
}

.contacts__point {
  display: flex;
  align-items: center;
  gap: var(--space-4l);
  min-width: 0;
} 

.contacts__link-icon {
  flex-shrink: 0;
  margin-top: -2px;
}

.contacts__mail {
  display: flex;
  justify-self: flex-end;
  font-size: 18px;
  line-height: 1.3;
  overflow-wrap: anywhere;
}

.contacts__image {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 241 / 200;
  object-fit: cover;
  max-height: 600px;
}

@media (max-width: 1024px) {
  .contacts {
    grid-template-columns: 1fr;
  }

  .contacts__image {
    width: 100%;
    max-height: none;
  }
}

@media (max-width: 767px) {
  .contacts__content,
  .contacts__info {
    gap: var(--space-xl);
  }

  .contacts__hints {
    gap: var(--space-xs);
  }

  .contacts__point {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
    gap: var(--space-m);
  }

  .contacts__mail {
    font-size: 28px;
  }

  .contacts__plaque {
    width: 100%;
    min-width: 0;
    white-space: normal;
  }
}

@media (max-width: 479px) {
  .contacts__content {
    gap: var(--space-l);
  }

  .contacts__info h2 {
    font-size: 36px;
  }

  .contacts__number {
    width: 24px;
    font-size: 16px;
  }

  .contacts__mail {
    font-size: 22px;
    line-height: 1.2;
  }
}
</style>
