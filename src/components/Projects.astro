---
const items = [
  {
    title: "Software\nfor veterinary clinics",
    desc: "Helps manage appointments, patient records, inpatient treatment workflows, and day-to-day operations.",
    tags: ["Health tech", "User Experience Design (UX)", "Prototyping", "Interaction Design", "User Testing & Feedback"],
    image: "/images/projects-vet.jpg",
    href: "/projects/vet/",
  },
  {
    title: "SaaS service is a data-driven\nwebsite optimization",
    desc: "Using tools like heat maps and A/B testing, teams can validate hypotheses.",
    tags: ["SaaS", "User Experience Design (UX)", "Prototyping", "User Interface Design (UI)", "Web design", "3D graphics"],
    image: "/images/projects-saas.jpg",
    href: "/projects/saas/",
  },
];
---
<section id="projects" class="sec">
  <div class="in">
    <h2 class="h2">Projects</h2>

    <div class="list">
      {items.map((p) => (
        <article class="card">
          <div class="text">
            <h3 class="t">{p.title}</h3>
            <p class="d">{p.desc}</p>

            <div class="tags">
              {p.tags.map((x) => <span class="tag">{x}</span>)}
            </div>

            <a class="more" href={p.href}>see more</a>
          </div>

          <figure class="img">
            <img src={p.image} alt="" loading="lazy" decoding="async" />
          </figure>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
@use "../styles/tokens.scss" as *;

.sec { padding-block: 28px; }
.in { @include container; }
.h2 { margin: 0 0 12px; font-size: 40px; font-weight: 400; letter-spacing: -0.02em; }

.list { display: grid; gap: 18px; }
.card {
  background: $panel;
  border: 1px solid $line;
  padding: 18px;
  display: grid;
  gap: 16px;
  @media (min-width: 900px) {
    grid-template-columns: 1fr 1.2fr;
    align-items: center;
    padding: 28px;
  }
}
.text { max-width: 560px; }
.t { margin: 0; font-weight: 400; line-height: 1.15; font-size: clamp(22px, 3.2vw, 34px); }
.d { margin: 10px 0 0; color: $muted; font-size: 14px; line-height: 1.5; }
.tags { margin-top: 12px; display: flex; gap: 8px 10px; flex-wrap: wrap; color: $muted; font-size: 12px; }
.tag { white-space: nowrap; }
.more { display: inline-block; margin-top: 14px; text-decoration: underline; font-size: 14px; }
.img { margin: 0; background: #fff; border: 1px solid $line; }
</style>