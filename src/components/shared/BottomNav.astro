---

import DownloadIcon from "../icons/ArrowIcon.astro";
import type { NavItem } from "../../types";

const { navItems, heading } = Astro.props as { navItems: [NavItem, NavItem], heading: string };
---

<div class="nav-bottom">
  <div class="nav-bottom__heading">
    <h4>{heading}</h4>
  </div>
  <nav class="nav-bottom__nav">
    {navItems.map((navItem) =>
      <a href={navItem.href} class="nav-bottom__card">
        <div class="nav-bottom__image">
          <img src={navItem.image.src} alt={navItem.image.alt}/>
        </div>
        <div class="nav-bottom__content">
          <span class="nav-bottom__title">{navItem.title}</span>
          <span class="nav-bottom__link">
            {navItem.direction === 'previous' ? (
              <>
                <span class="nav-bottom__icon" aria-hidden="true">
                  <DownloadIcon />
                </span>
                <span class="nav-bottom__label">{navItem.direction}</span>
              </>
            ) : (
              <>
                <span class="nav-bottom__label">{navItem.direction}</span>
                <span class="nav-bottom__icon nav-bottom__icon--next" aria-hidden="true">
                  <DownloadIcon />
                </span>
              </>
            )}
          </span>
        </div>
      </a>
    )}
  </nav>
</div>

<style lang="scss">
.nav-bottom {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.nav-bottom__heading {
  color: var(--color-dark);
  font-size: 34px;
  font-style: normal;
  font-weight: 400;
  line-height: 1.15;
  border-bottom: 1px solid var(--color-opacity-30);

  h4 {
    padding-bottom: 16px;
  }
}

.nav-bottom__nav {
  display: flex;
  justify-content: space-between;
  gap: 20px;

  @media (max-width: 439px) {
    flex-direction: column;
  }
}

.nav-bottom__card {
  display: flex;
  flex-direction: column;
  background: var(--color-surface);
}

.nav-bottom__image {
  height: 176px;
  border: 0;
  background: var(--color-dark);
  padding-block: 32px;
  display: flex;
  align-items: center;

  img {
    height: 100%;
    width: 100%;
    padding: 0 32px;
    object-fit: contain;
  }
}

.nav-bottom__content {
  padding: 14px;
}

.nav-bottom__link {
  display: inline-flex;
  align-items: center;
  gap: 6px;

  svg {
    margin-top: -1px;
  }
}

.nav-bottom__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.nav-bottom__icon--next {
  transform: rotate(180deg);
}

.nav-bottom__content {
  display: inline-flex;
  flex-direction: column;
  gap: 50px;
}

.nav-bottom__title {
  font-size: 24px;
  line-height: 1.2;
}

.nav-bottom__label {
  font-size: 14px;
  line-height: 1.3;
}
</style>
