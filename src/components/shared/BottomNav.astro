---
import type { NavItem } from "../../types";
import { content } from "../../content";

import ArrowIcon from "../icons/ArrowIcon.astro";
import ImageComponent from "./ImageComponent.astro";

const { navItems, heading } = Astro.props as { navItems: [NavItem, NavItem]; heading: string };
const navImageRatio = "260 / 220";
const navImageSizes = "(max-width: 767px) 100vw, 50vw";
---

<div class="nav-bottom">
  <div class="nav-bottom__heading">
    <h4>{heading}</h4>
  </div>
  <nav class="nav-bottom__nav">
    {navItems.map((navItem) => (
      <a href={navItem.href} class="nav-bottom__card" aria-label={`View ${navItem.title}`}>
        <div class="nav-bottom__image">
          <ImageComponent
            class="nav-bottom__media"
            src={navItem.image.src}
            srcset={navItem.image.srcset}
            sizes={navItem.image.sizes ?? navImageSizes}
            alt={navItem.image.alt}
            ratio={navImageRatio}
            mode="contain"
            frameBg="var(--color-dark)"
            skeletonBg="#191919"
            shimmerColor="rgba(255, 255, 255, 0.12)"
          />
        </div>
        <div class="nav-bottom__content">
          <span class="nav-bottom__title">{navItem.title}</span>
          <span class="nav-bottom__link">
            {navItem.direction === "previous" ? (
              <>
                <span class="nav-bottom__icon" aria-hidden="true">
                  <ArrowIcon />
                </span>
                <span class="nav-bottom__label">{content.shared.navigation.bottomNav.previousLabel}</span>
              </>
            ) : (
              <>
                <span class="nav-bottom__label">{content.shared.navigation.bottomNav.nextLabel}</span>
                <span class="nav-bottom__icon nav-bottom__icon--next" aria-hidden="true">
                  <ArrowIcon />
                </span>
              </>
            )}
          </span>
        </div>
      </a>
    ))}
  </nav>
</div>

<style lang="scss">
.nav-bottom {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding-bottom: 32px;
}

.nav-bottom__heading {
  color: var(--color-dark);
  font-size: 34px;
  font-style: normal;
  font-weight: 400;
  line-height: 1.15;
  border-bottom: 1px solid var(--color-opacity-30);

  h4 {
    padding-bottom: 16px;
  }
}

.nav-bottom__nav {
  display: flex;
  justify-content: space-between;
  gap: 20px;

  @media (max-width: 767px) {
    flex-direction: column;
  }
}

.nav-bottom__card {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  width: 272px;
  min-width: 272px;
  max-width: 272px;
  background: var(--color-surface);

  &:hover {
    background-color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 767px) {
    width: 100%;
    min-width: 100%;
    max-width: 100%;
  }
}

.nav-bottom__image {
  height: 176px;
  border: 0;
  background: var(--color-dark);
  display: grid;
  place-items: stretch;
  overflow: hidden;
  padding-inline: 24px;

  @media (max-width: 767px) {
    height: auto;
    padding: 24px 48px;
  }
}

:global(.nav-bottom__media) {
  width: 100%;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  align-self: stretch;
  justify-self: stretch;
  padding-inline: 24px;
}

:global(.nav-bottom__media.image-frame--contain) {
  aspect-ratio: auto;
}

.nav-bottom__content {
  padding: 14px;
}

.nav-bottom__link {
  display: inline-flex;
  align-items: center;
  gap: 6px;

  svg {
    margin-top: -1px;
  }
}

.nav-bottom__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease;
}

.nav-bottom__icon--next {
  transform: rotate(180deg);
}

.nav-bottom__content {
  display: inline-flex;
  flex-direction: column;
  height: 125px;
  justify-content: space-between;
}

.nav-bottom__title {
  font-size: 24px;
  line-height: 1.2;
}

.nav-bottom__label {
  font-size: 14px;
  line-height: 1.3;
}
</style>
