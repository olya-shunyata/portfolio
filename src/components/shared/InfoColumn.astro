---
import type { InfoItem } from '../../types';

const { item, titleSize = "24px", descriptionSize = "16px" } = Astro.props as { item: InfoItem, titleSize?: string, descriptionSize?: string};
---
<div class:list={[
  "info-column",
  { "info-column--selected": item?.selected || false }
]} style={`--info-column-title-size: ${titleSize}; --info-column-description-size: ${descriptionSize};`}>
  <h3 class="info-column__title">{item.title}</h3>
  <div class="info-column__description">
      {item.description.map((list) => (
        <ul class="info-column__list">
          {list.map((point) => (
            <li class="info-column__point">
              {typeof point === "string"
                ? point
                : point.map((part) => (
                  <span class:list={[
                    "info-column__inline-part",
                    { "info-column__inline-part--accent": part.accent }
                  ]}>
                    {part.text}
                  </span>
                ))}
            </li>
          ))}
        </ul>
      ))}
  </div>
</div>

<style lang="scss">
.info-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);

    @media (max-width: 1024px) {
        max-width: 400px; 
    }
}

.info-column--selected {
    position: relative;
    padding: 4px 6px;
    border: 1.5px solid var(--color-accent);
    margin-top: -4px;
    margin-left: -6px;
}

.info-column--selected::before,
.info-column--selected::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 9px;
    height: 22px;
    background: var(--color-accent);
    border-radius: 4px;
    transform: translateY(-50%);
}

.info-column--selected::before {
    left: -5px;
}

.info-column--selected::after {
    right: -5px;
}

.info-column__title {
    font-size: var(--info-column-title-size);
    font-style: normal;
    font-weight: 400;
    line-height: 1.2;
}

.info-column__description {
    font-size: var(--info-column-description-size);
    color: rgba(0, 0, 0, 0.62);
    font-style: normal;
    font-weight: 400;
    line-height: 1.3;
    display: flex;
    gap: 70px;
}

.info-column__list {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.info-column__point {
    display: block;
}

.info-column__inline-part {
    display: inline;
}

.info-column__inline-part--accent {
    background: linear-gradient(
      180deg,
      transparent 12%,
      var(--color-accent) 12%,
      var(--color-accent) 88%,
      transparent 88%
    );
}
</style>
