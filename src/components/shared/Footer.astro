---
import { buildUrl } from "../../scripts/path-utils";
import BrandName from "../shared/BrandName.astro";
import { content } from "../../content";

const links = [
  { label: content.shared.footer.about.label, href: buildUrl("/about") },
];

const brandInfo = {
  name: content.shared.brand.displayName,
  profession: content.shared.brand.profession,
  experience: `${content.shared.brand.experienceStart} - ${new Date().getFullYear()}`,
};
---

<footer class="site-footer">
  <div class="container site-footer__container">
    <a class="site-footer__brand" href={buildUrl("/")} aria-label={content.shared.brand.ariaLabel}>
      <BrandName data={brandInfo} />
    </a>
    <a class="site-footer__about-link" href={links[0].href} aria-label={content.shared.footer.about.ariaLabel}>
      {links[0].label}
    </a>
  </div>
</footer>

<style lang="scss">
.site-footer {
  margin-top: var(--space-5xl);
}

.site-footer__container {
  padding-block: var(--space-xl);
  display: flex;
  gap: var(--space-xl);
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.site-footer__brand {
  display: flex;

  &:hover {
    text-decoration: none;
  }
}

.site-footer__name {
  font-size: var(--font-size-ui);
  line-height: var(--line-height-ui);
  letter-spacing: var(--letter-spacing-brand);
  text-transform: uppercase;
}

.site-footer__meta {
  font-size: 11px;
  line-height: 1.3;
}

.site-footer__about-link {
  font-size: var(--font-size-ui);
  line-height: var(--line-height-ui);
  letter-spacing: var(--letter-spacing-ui);
  text-transform: uppercase;

  &:hover {
    color: var(--color-accent-dark);
    text-decoration: none;
  }
}
</style>
