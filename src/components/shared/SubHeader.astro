---
import type { InfoItem } from '../../types';

const { item, type = "h3" } = Astro.props as { item: InfoItem; type?: "h3" | "h4" };
const Tag = type;
const normalizeDescriptionLines = (description?: InfoItem["description"]) => {
  const lines = Array.isArray(description)
    ? description
    : description
      ? [description]
      : [];

  return lines.map((line, index) => {
    if (index === lines.length - 1 || typeof line !== "string" || /\s$/.test(line)) {
      return line;
    }

    return `${line} `;
  });
};

const descriptionLines = normalizeDescriptionLines(item?.description);
---

<>
    <span class="content-header">
        <Tag>{item.title}</Tag>
        {descriptionLines.length > 0 && <span class="content-header__sub">
          {descriptionLines.map((line) => (
            <span>{line}</span>
          ))}
        </span>}
    </span>
</>

<style lang="scss">
.content-header {
    grid-column: 3 / 6;
    display: grid;
    gap: 16px;
    color: var(--color-text);
    font-size: 24px;
    font-weight: var(--font-weight-regular);
    line-height: 1.2;
}

.content-header__sub {
    display: flex;
    flex-direction: column;
    font-size: 16px;
    font-style: normal;
    font-weight: var(--font-weight-regular);
    line-height: 1.3;
    color: var(--color-muted);

    @media (max-width: 767px) {
        display: inline;
    }
}

@media (max-width: 767px) {
    .content-header {
        grid-column: auto;
    }
}
</style>
