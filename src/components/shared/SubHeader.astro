---
import type { InfoItem } from '../../types';

const { item, type = "h3" } = Astro.props as { item: InfoItem; type?: "h3" | "h4" };
const Tag = type;
---

<>
    <span class="content-header">
        <Tag>{item.title}</Tag>
        {item?.description && <span class="content-header__sub">{item.description}</span>}
    </span>
</>

<style lang="scss">
.content-header {
    grid-column: 3 / 6;
    display: grid;
    gap: 16px;
    color: var(--color-text);
    font-size: 24px;
    font-weight: var(--font-weight-regular);
    line-height: 1.2;
}

.content-header__sub {
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 1.3;
}

@media (max-width: 768px) {
    .content-header {
        grid-column: auto;
    }
}
</style>