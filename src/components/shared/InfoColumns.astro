---
import type { InfoItem } from '../../types';

const {
  items,
  layout = "main",
  widths = layout === "main" ? ["118px", "419px", "451px"] : ["108px", "339px", "425px"],
  gaps = layout === "main" ? ["140px"] : ["160px", "128px"],
  descriptionGap = layout === "main" ? "70px" : "0px",
} = Astro.props as {
  items: InfoItem[];
  layout?: "main" | "case-study";
  widths?: [string, string, string] | string[];
  gaps?: [string] | [string, string] | string[];
  descriptionGap?: string;
};

const [firstItem, secondItem, thirdItem] = items;
---

{layout === "case-study" ? (
  <div
    class="info-columns info-columns--case-study"
    style={`--info-columns-group-gap: ${gaps[0] ?? "160px"}; --info-columns-case-gap: ${gaps[1] ?? "128px"}; --info-columns-description-gap: ${descriptionGap};`}
  >
    <div
      class:list={[
        "info-columns__column",
        { "info-columns__column--selected": firstItem?.selected },
      ]}
      style={`--info-columns-column-width: ${widths[0] ?? "108px"};`}
    >
      <h3 class="info-columns__title">{firstItem.title}</h3>
      <div class="info-columns__description">
        {firstItem.description.map((list) => (
          <ul class="info-columns__list">
            {list.map((point) => (
              <li class="info-columns__point">
                {typeof point === "string"
                  ? point
                  : point.map((part) => (
                    <span class:list={[
                      "info-columns__inline-part",
                      { "info-columns__inline-part--accent": part.accent }
                    ]}>
                      {part.text}
                    </span>
                  ))}
              </li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <div class="info-columns__group">
      {[secondItem, thirdItem].map((item, index) => (
        <div
          class:list={[
            "info-columns__column",
            { "info-columns__column--selected": item.selected },
          ]}
          style={`--info-columns-column-width: ${widths[index + 1] ?? "343px"};`}
        >
          <h3 class="info-columns__title">{item.title}</h3>
          <div class="info-columns__description">
            {item.description.map((list) => (
              <ul class="info-columns__list">
                {list.map((point) => (
                  <li class="info-columns__point">
                    {typeof point === "string"
                      ? point
                      : point.map((part) => (
                        <span class:list={[
                          "info-columns__inline-part",
                          { "info-columns__inline-part--accent": part.accent }
                        ]}>
                          {part.text}
                        </span>
                      ))}
                  </li>
                ))}
              </ul>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
) : (
  <div
    class="info-columns info-columns--main"
    style={`--info-columns-main-gap: ${gaps[0] ?? "140px"}; --info-columns-description-gap: ${descriptionGap};`}
  >
    {items.map((item, index) => (
      <div
        class:list={[
          "info-columns__column",
          { "info-columns__column--selected": item.selected },
        ]}
        style={`--info-columns-column-width: ${widths[index] ?? "320px"};`}
      >
        <h3 class="info-columns__title">{item.title}</h3>
        <div class="info-columns__description">
          {item.description.map((list) => (
            <ul class="info-columns__list">
              {list.map((point) => (
                <li class="info-columns__point">
                  {typeof point === "string"
                    ? point
                    : point.map((part) => (
                      <span class:list={[
                        "info-columns__inline-part",
                        { "info-columns__inline-part--accent": part.accent }
                      ]}>
                        {part.text}
                      </span>
                    ))}
                </li>
              ))}
            </ul>
          ))}
        </div>
      </div>
    ))}
  </div>
)}

<style lang="scss">
.info-columns {
  width: 100%;
}

.info-columns--main {
  display: flex;
  align-items: flex-start;
  gap: var(--info-columns-main-gap);
}

.info-columns--case-study {
  display: flex;
  align-items: flex-start;
  gap: var(--info-columns-group-gap);
}

.info-columns__group {
  display: flex;
  align-items: flex-start;
  gap: var(--info-columns-case-gap);
}

.info-columns__column {
  display: flex;
  flex: 0 0 var(--info-columns-column-width);
  flex-direction: column;
  gap: var(--space-m);
  width: var(--info-columns-column-width);
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.info-columns__column--selected {
  position: relative;
  padding: 4px 6px;
  border: 1.5px solid var(--color-accent);
}

.info-columns__column--selected::before,
.info-columns__column--selected::after {
  content: "";
  position: absolute;
  top: 50%;
  width: 9px;
  height: 22px;
  background: var(--color-accent);
  border-radius: 4px;
  transform: translateY(-50%);
}

.info-columns__column--selected::before {
  left: -5px;
}

.info-columns__column--selected::after {
  right: -5px;
}

.info-columns__title {
  margin: 0;
  font-size: 24px;
  font-style: normal;
  font-weight: 400;
  line-height: 1.2;
}

.info-columns__description {
  display: flex;
  gap: var(--info-columns-description-gap);
  color: rgba(0, 0, 0, 0.62);
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: 1.3;
}

.info-columns__list {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.info-columns__point {
  display: block;
}

.info-columns__inline-part {
  display: inline;
}

.info-columns__inline-part--accent {
  background: linear-gradient(
    180deg,
    transparent 12%,
    var(--color-accent) 12%,
    var(--color-accent) 88%,
    transparent 88%
  );
}

@media (max-width: 1024px) {
  .info-columns--main,
  .info-columns--case-study,
  .info-columns__group {
    gap: var(--space-6l);
  }

  .info-columns--case-study {
    flex-direction: column;
  }

  .info-columns__group {
    width: 100%;
  }
}

@media (max-width: 767px) {
  .info-columns--main,
  .info-columns--case-study,
  .info-columns__group,
  .info-columns__description {
    flex-direction: column;
  }

  .info-columns--main,
  .info-columns--case-study,
  .info-columns__group {
    gap: 40px;
  }

  .info-columns__description {
    gap: var(--space-l);
  }

  .info-columns__column {
    flex-basis: auto;
    width: 100%;
  }
}
</style>
