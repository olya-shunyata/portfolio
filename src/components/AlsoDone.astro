---
const img = "/images/also-done.jpg";
---
<section class="sec">
  <div class="in">
    <h2 class="h2">Also I have done</h2>
    <figure class="img">
      <img src={img} alt="" loading="lazy" decoding="async" />
    </figure>
  </div>
</section>

<style lang="scss">
@use "../styles/tokens.scss" as *;

.sec { padding-block: 28px; }
.in { @include container; }
.h2 { margin: 0 0 12px; font-size: 40px; font-weight: 400; letter-spacing: -0.02em; }
.img { margin: 0; border: 1px solid $line; background: $panel; }
</style>