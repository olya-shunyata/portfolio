---
const img = "/images/confidential.jpg";
---
<section class="sec">
  <div class="in">
    <h2 class="h2">Confidential projects</h2>

    <div class="top">
      <div>
        <div class="k">My roles</div>
        <div class="v">UX / UI designer<br />Product designer</div>
      </div>
      <div>
        <div class="k">Fields</div>
        <div class="v">Studios, startups, product teams. FinTech, Travel, Property, exhibitions.</div>
      </div>
      <div>
        <div class="k">Disciplines</div>
        <div class="v">UX, UI, Interaction, Design system, A/B testing, 2D/3D, AI visuals</div>
      </div>
    </div>

    <figure class="img">
      <img src={img} alt="" loading="lazy" decoding="async" />
    </figure>
  </div>
</section>

<style lang="scss">
@use "../styles/tokens.scss" as *;

.sec { padding-block: 28px; }
.in { @include container; }
.h2 { margin: 0 0 12px; font-size: 40px; font-weight: 400; letter-spacing: -0.02em; }
.top { border-top: 1px solid $line; padding-top: 14px; display: grid; gap: 12px; @media (min-width: 900px){ grid-template-columns: 1fr 1.5fr 1.5fr; } }
.k { font-size: 12px; color: $muted; margin-bottom: 6px; }
.v { font-size: 13px; line-height: 1.5; }
.img { margin: 14px 0 0; border: 1px solid $line; background: #000; }
</style>