---
import type { InfoRowSection, InfoItem } from "../../types";
import { content } from "../../content";

import InfoRows from "../shared/InfoRows.astro";
import SubHeader from "../shared/SubHeader.astro";
import ImageComponent from "../shared/ImageComponent.astro";
import { buildResponsiveImage } from "../../scripts/responsive-images";
import overviewAsset from "../../assets/images/vet/dashboard-overview.png";
import patientAsset from "../../assets/images/vet/dashboard-patient.png";
import tasksAsset from "../../assets/images/vet/dashboard-tasks.png";
import catAsset from "../../assets/images/vet/dashboard-cat.png";
import tableAsset from "../../assets/images/vet/dashboard-table.png";
import tabsAsset from "../../assets/images/vet/dashboard-tabs.png";
import markersAsset from "../../assets/images/vet/dashboard-markers.png";
import clinicAsset from "../../assets/images/vet/testing-clinic.png";
import mobilesAsset from "../../assets/images/vet/testing-mobiles.png";

const dashboardContent = content.projects.vet.dashboard;
const heading: InfoRowSection = {
  title: dashboardContent.heading.title,
  description: dashboardContent.heading.description,
  contentWidth: "447px",
};

const subHeader: InfoItem = {
  title: dashboardContent.subHeaderTitle,
};

const browserSizes = "100vw";
const patientMediaSizes = "(max-width: 767px) 100vw, 50vw";
const checklistSizes = "(max-width: 767px) 100vw, 50vw";
const testingSizes = "(max-width: 767px) 100vw, 50vw";
const tabsSizes = "321px";
const markersSizes = "92px";
const [overviewImage, patientImage, tasksImage, catImage, tableImage, tabsImage, markersImage, clinicImage, mobilesImage] = await Promise.all([
  buildResponsiveImage({ asset: overviewAsset, profile: "screenshot", maxDisplayWidth: 1180 }),
  buildResponsiveImage({ asset: patientAsset, profile: "screenshot", maxDisplayWidth: 1180 }),
  buildResponsiveImage({ asset: tasksAsset, profile: "screenshot", maxDisplayWidth: 1180 }),
  buildResponsiveImage({ asset: catAsset, profile: "screenshot", maxDisplayWidth: 508 }),
  buildResponsiveImage({ asset: tableAsset, profile: "screenshot", maxDisplayWidth: 757 }),
  buildResponsiveImage({ asset: tabsAsset, profile: "detail", maxDisplayWidth: 321 }),
  buildResponsiveImage({ asset: markersAsset, profile: "detail", maxDisplayWidth: 92 }),
  buildResponsiveImage({ asset: clinicAsset, profile: "showcase", maxDisplayWidth: 760 }),
  buildResponsiveImage({ asset: mobilesAsset, profile: "showcase", maxDisplayWidth: 760 }),
]);

const images = {
  overview: { ...overviewImage, sizes: browserSizes, alt: dashboardContent.alts.overview },
  patient: { ...patientImage, sizes: browserSizes, alt: dashboardContent.alts.patient },
  tasks: { ...tasksImage, sizes: browserSizes, alt: dashboardContent.alts.tasks },
  cat: { ...catImage, sizes: patientMediaSizes, alt: dashboardContent.alts.cat },
  table: { ...tableImage, sizes: checklistSizes, alt: dashboardContent.alts.table },
  tabs: { ...tabsImage, sizes: tabsSizes, alt: dashboardContent.alts.tabs },
  markers: { ...markersImage, sizes: markersSizes, alt: dashboardContent.alts.markers },
  clinic: { ...clinicImage, sizes: testingSizes, alt: dashboardContent.alts.clinic },
  mobiles: { ...mobilesImage, sizes: testingSizes, alt: dashboardContent.alts.mobiles },
};
---
<div class="vet-dashboard">
  <div class="grid-layout vet-dashboard__heading-layout">
    <div class="vet-dashboard__heading">
      <InfoRows sections={[heading]} />
    </div>
    <SubHeader item={subHeader} />
  </div>

  <article class="vet-dashboard__panel vet-dashboard__panel--overview">
    <ImageComponent class="vet-dashboard__browser" src={images.overview.src} srcset={images.overview.srcset} sizes={images.overview.sizes} alt={images.overview.alt} ratio="2378 / 1592" />
    <div class="grid-layout vet-dashboard__overview-layout">
      <div class="vet-dashboard__copy vet-dashboard__copy--wide">
        <p>{dashboardContent.copy.overview}</p>
        <ImageComponent class="vet-dashboard__tabs" src={images.tabs.src} srcset={images.tabs.srcset} sizes={images.tabs.sizes} alt={images.tabs.alt} ratio="107 / 16" mode="intrinsic" />
      </div>
      <div class="vet-dashboard__copy vet-dashboard__copy--compact">
        <p>{dashboardContent.copy.overviewSupport}</p>
        <ImageComponent class="vet-dashboard__markers" src={images.markers.src} srcset={images.markers.srcset} sizes={images.markers.sizes} alt={images.markers.alt} ratio="23 / 7" mode="intrinsic" />
      </div>
    </div>
  </article>

  <article class="vet-dashboard__panel vet-dashboard__panel--patient">
    <ImageComponent class="vet-dashboard__browser" src={images.patient.src} srcset={images.patient.srcset} sizes={images.patient.sizes} alt={images.patient.alt} ratio="2378 / 1592" />
    <div class="grid-layout vet-dashboard__patient-top">
      <p class="vet-dashboard__patient-heading">{dashboardContent.copy.patientTop}</p>
      <div class="vet-dashboard__patient-layout">
        <ImageComponent class="vet-dashboard__patient-media" src={images.cat.src} srcset={images.cat.srcset} sizes={images.cat.sizes} alt={images.cat.alt} ratio="1016 / 966" mode="contain" />
        <div class="vet-dashboard__checklist">
          <ImageComponent class="vet-dashboard__checklist-image" src={images.table.src} srcset={images.table.srcset} sizes={images.table.sizes} alt={images.table.alt} ratio="1514 / 440" mode="contain" />
          <p class="vet-dashboard__body">{dashboardContent.copy.patientBottom}</p>
        </div>
      </div>
    </div>
  </article>

  <article class="vet-dashboard__panel vet-dashboard__panel--tasks">
    <div class="vet-dashboard__tasks-header grid-layout">
      <p class="vet-dashboard__body">{dashboardContent.copy.tasksLead}</p>
      <p class="vet-dashboard__body">{dashboardContent.copy.tasksSupport}</p>
    </div>
    <ImageComponent class="vet-dashboard__browser" src={images.tasks.src} srcset={images.tasks.srcset} sizes={images.tasks.sizes} alt={images.tasks.alt} ratio="2378 / 1592" />
    <p class="vet-dashboard__note">{dashboardContent.copy.tasksFoot}</p>
  </article>

  <div class="vet-dashboard__testing-media">
    <figure class="vet-dashboard__testing-frame">
      <ImageComponent class="vet-dashboard__testing-image" src={images.clinic.src} srcset={images.clinic.srcset} sizes={images.clinic.sizes} alt={images.clinic.alt} ratio="1360 / 1300" />
    </figure>
    <figure class="vet-dashboard__testing-frame vet-dashboard__testing-frame--light">
      <ImageComponent class="vet-dashboard__testing-image" src={images.mobiles.src} srcset={images.mobiles.srcset} sizes={images.mobiles.sizes} alt={images.mobiles.alt} ratio="1360 / 1300" />
    </figure>
  </div>
</div>

<style lang="scss">
.vet-dashboard {
  --vet-tabs-width: 321px;
  --vet-browser-max-width: 1189px;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  grid-template-rows:
    auto 40px
    auto 40px
    auto 24px
    auto 16px
    auto;

  @media (max-width: 767px) {
    grid-template-rows:
      auto 32px
      auto 32px
      auto 72px
      auto 12px
      auto;
  }
}

.vet-dashboard > .grid-layout:first-child {
  grid-row: 1;
}

.vet-dashboard__panel--overview {
  grid-row: 3;
}

.vet-dashboard__panel--patient {
  grid-row: 5;
}

.vet-dashboard__panel--tasks {
  grid-row: 7;
}

.vet-dashboard__testing-media {
  grid-row: 9;
}

.vet-dashboard__heading {
  grid-column: 3 / 6;
}

.vet-dashboard__heading-layout {
  gap: 48px;

  @media (max-width: 1023px) {
    gap: 40px;
  }
}

.vet-dashboard__patient-top {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  grid-template-rows: auto 1fr;
  gap: 60px;

  @media (max-width: 767px) {
    gap: 40px;
  }
}

.vet-dashboard__patient-layout {
  grid-column: span 6;
}

.vet-dashboard__panel {
  display: flex;
  flex-direction: column;
  gap: 32px;
}

:global(.vet-dashboard__browser) {
  max-width: var(--vet-browser-max-width);
}

.vet-dashboard__patient-heading {
  display: grid;
  grid-column: span 2;
  color: var(--color-muted);

  @media (max-width: 1023px) {
    width: 100%;
    grid-column: 1 / span 6;
  }
}

.vet-dashboard__checklist {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
  grid-template-areas:
    "checklist checklist"
    ". body";
  gap: 40px;
  align-self: stretch;

  :global(.vet-dashboard__checklist-image) {
    grid-area: checklist;
    width: 100%;
  }

  .vet-dashboard__body {
    grid-area: body;
  }

  @media (max-width: 1023px) {
    gap: 32px;
    grid-template-areas:
      "checklist checklist"
      "body .";
    grid-template-rows: repeat(2, auto);

    .vet-dashboard__body {
      grid-area: body;
      align-self: start;
    }
  }

  @media (max-width: 767px) {
    gap: 32px;
    grid-template-areas:
      "checklist checklist"
      "body body";

    .vet-dashboard__body {
      grid-area: body;
    }
  }
}

.vet-dashboard__panel--overview {
  padding: 90px;

  @media (max-width: 767px) {
    padding: 60px 24px;
  }
}

.vet-dashboard__panel--patient {
  padding: 90px 30px 90px 60px;

  @media (max-width: 767px) {
    padding: 60px 24px;
  }
}

.vet-dashboard__panel--overview,
.vet-dashboard__panel--patient {
  background: var(--color-dark-grey);
}

.vet-dashboard__panel--tasks {
  background: var(--color-light-grey);
  padding: 90px;

  @media (max-width: 767px) {
    padding: 60px 24px;
  }
}

.vet-dashboard__testing-media {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;

  @media (max-width: 767px) {
    grid-template-columns: 1fr;
    gap: 12px;
  }
}

.vet-dashboard__testing-frame {
  margin: 0;
}

.vet-dashboard__testing-frame--light {
  background: var(--color-light-grey);
}

:global(.vet-dashboard__testing-image) {
  display: block;
  width: 100%;
}

.vet-dashboard__tasks-header {
  height: max-content;

  .vet-dashboard__body:first-child {
    grid-column: span 2;
  }

  .vet-dashboard__body:last-child {
    grid-column: 5 / span 2;
  }

  @media (max-width: 767px) {
    display: flex;
    flex-direction: column;
    gap: 20px;

    .vet-dashboard__body:first-child,
    .vet-dashboard__body:last-child {
      grid-column: unset;
      width: 100%;
    }
  }
}

:global(.vet-dashboard__browser),
:global(.vet-dashboard__patient-media) {
  display: block;
  width: 100%;
}

.vet-dashboard__two-column {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 48px;
}

.vet-dashboard__two-column > * {
  grid-column: span 2;
}

.vet-dashboard__copy,
.vet-dashboard__body,
.vet-dashboard__note {
  margin: 0;
  color: rgba(0, 0, 0, 0.62);
  font-size: 16px;
  line-height: 1.3;
}

.vet-dashboard__copy {
  display: flex;
  flex-direction: column;
  gap: 24px;

  @media (max-width: 767px) {
    gap: 16px;
  }
}

.vet-dashboard__copy--wide,
.vet-dashboard__copy--compact {
  grid-column: span 2;
}

.vet-dashboard__overview-layout .vet-dashboard__copy--wide {
  grid-column: 3 / span 2;
}

.vet-dashboard__overview-layout .vet-dashboard__copy--compact {
  grid-column: 5 / span 2;
}

.vet-dashboard__copy p,
.vet-dashboard__body,
.vet-dashboard__note {
  margin: 0;
}

:global(.vet-dashboard__tabs),
:global(.vet-dashboard__markers) {
  align-self: flex-start;
}

:global(.vet-dashboard__tabs) {
  height: 48px;

  @media (max-width: 767px) {
    height: auto;
  }
}

:global(.vet-dashboard__markers) {
  height: 28px;

  @media (max-width: 767px) {
    height: 24px;
  }
}

.vet-dashboard__patient-top {
  grid-column: span 2;
  line-height: 1.2;
}

.vet-dashboard__patient-layout {
  display: flex;
  align-items: start;
  gap: 20px;

  @media (max-width: 1023px) {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (max-width: 767px) {
    gap: 12px;
  }
}

:global(.vet-dashboard__patient-media) {
  flex: none;
  width: 508px;
  aspect-ratio: 61 / 58;

  @media (max-width: 1023px) {
    width: 100%;
  }
}

.vet-dashboard__two-column--tasks > * {
  grid-column: span 2;
}

.vet-dashboard__note {
  max-width: 446px;
}

@media (min-width: 1024px) {
  .vet-dashboard__overview-layout {
    width: 100%;
    max-width: var(--vet-browser-max-width);
  }

  .vet-dashboard__overview-layout .vet-dashboard__copy--compact {
    width: var(--vet-tabs-width);
    justify-self: end;
  }

  .vet-dashboard__overview-layout .vet-dashboard__copy--wide > p,
  .vet-dashboard__overview-layout .vet-dashboard__copy--compact > p {
    width: var(--vet-tabs-width);
    max-width: 100%;
  }

  .vet-dashboard__overview-layout .vet-dashboard__copy--compact :global(.vet-dashboard__markers) {
    align-self: flex-start;
  }
}

@media (max-width: 1023px) {
  .vet-dashboard__heading {
    grid-column: auto;
  }

  .vet-dashboard__overview-layout .vet-dashboard__copy--wide,
  .vet-dashboard__overview-layout .vet-dashboard__copy--compact {
    grid-column: auto;
  }

  .vet-dashboard__overview-layout {
    gap: 28px;
  }
}

@media (max-width: 767px) {
  .vet-dashboard__two-column,
  .vet-dashboard__two-column--tasks,
  .vet-dashboard__patient-layout {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .vet-dashboard__copy,
  .vet-dashboard__body,
  .vet-dashboard__note,
  .vet-dashboard__tab {
    font-size: 16px;
  }
}
</style>
