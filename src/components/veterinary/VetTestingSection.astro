---
import { content } from "../../content";

const title = content.projects.vet.testing.title;
const description = content.projects.vet.testing.paragraphs;
---
<div class="vet-testing">
  <div class="grid-layout">
    <div class="vet-testing__content">
      <h3 class="vet-testing__title">{title}</h3>
      <div class="vet-testing__description">
        {description.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </div>
</div>

<style lang="scss">
.vet-testing {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.vet-testing__content {
  grid-column: 3 / 5;
  display: flex;
  flex-direction: column;
  gap: 18px;

  @media (max-width: 1023px) {
    grid-column: auto;
  }
}

.vet-testing__title {
  margin: 0;
  color: var(--color-text);
  font-size: 34px;
  line-height: 1.3;
}

.vet-testing__description {
  color: var(--color-opacity-60);
  font-size: 16px;
  line-height: 1.3;
  display: flex;
  flex-direction: column;
  gap: 20px;

  @media (max-width: 767px) {
    gap: 16px;
  }
}

.vet-testing__media {
  @media (max-width: 767px) {
    grid-template-columns: 1fr;
    gap: 12px;
  }
}
</style>
