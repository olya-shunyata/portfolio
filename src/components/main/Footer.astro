---
import BrandName from "../shared/BrandName.astro"

const brandInfo = {
  name: "OLGA BIS",
  profession: "UX / UI DESIGNER",
  experience: `2020 - ${new Date().getFullYear()}`,
}
---

<footer class="site-footer">
  <div class="container site-footer__container">
    <BrandName data={brandInfo} />

    <a class="site-footer__about-link" href="#about">
      ABOUT ME
    </a>
  </div>
</footer>

<style lang="scss">
.site-footer {
  margin-top: var(--space-5xl);
  border-top: 1px solid var(--color-border);
}

.site-footer__container {
  padding-block: var(--space-xl);
  display: flex;
  gap: var(--space-xl);
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.site-footer__brand {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.site-footer__name {
  font-size: var(--font-size-ui);
  line-height: var(--line-height-ui);
  letter-spacing: var(--letter-spacing-brand);
  text-transform: uppercase;
}

.site-footer__meta {
  font-size: 11px;
  line-height: 1.3;
}

.site-footer__about-link {
  font-size: var(--font-size-ui);
  line-height: var(--line-height-ui);
  letter-spacing: var(--letter-spacing-ui);
  text-transform: uppercase;
}

</style>