---
const photo = "/images/contacts.jpg";
---
<section id="contacts" class="sec">
  <div class="in">
    <div class="grid">
      <div class="left">
        <div class="eyebrow">Contacts</div>
        <h2 class="h2">Let's get in touch</h2>

        <div class="actions">
          <a class="btn" href="https://t.me/your" target="_blank" rel="noreferrer">(1) Telegram</a>
          <a class="btn" href="https://linkedin.com/in/your" target="_blank" rel="noreferrer">(2) LinkedIn</a>
          <a class="btn" href="/cv.pdf" target="_blank" rel="noreferrer">(3) CV</a>
        </div>

        <a class="mail" href="mailto:olgabis.design@gmail.com">olgabis.design@gmail.com</a>
      </div>

      <figure class="right">
        <img src={photo} alt="" loading="lazy" decoding="async" />
      </figure>
    </div>
  </div>
</section>

<style lang="scss">
@use "../styles/tokens.scss" as *;

.sec { padding-block: 28px; }
.in { @include container; }
.grid {
  border: 1px solid $line;
  background: $panel;
  display: grid;
  gap: 0;
  @media (min-width: 900px) { grid-template-columns: 1fr 1.6fr; }
}
.left { padding: 18px; display: grid; gap: 14px; }
.eyebrow { font-size: 12px; color: $muted; }
.h2 { margin: 0; font-size: clamp(28px, 4vw, 48px); font-weight: 400; letter-spacing: -0.02em; }
.actions { display: grid; gap: 10px; max-width: 220px; }
.btn { border: 1px solid $line; padding: 10px 12px; background: #fff; font-size: 13px; }
.mail { font-size: 16px; margin-top: 10px; }
.right { margin: 0; border-left: 1px solid $line; background: #000; }
.right img { width: 100%; height: 100%; object-fit: cover; }
@media (max-width: 899px) {
  .right { border-left: none; border-top: 1px solid $line; }
}
</style>