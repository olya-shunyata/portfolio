---
import type { Image } from "../../types";
import { buildUrl } from "../../scripts/path-utils";
import getTimezoneLabel from "../../scripts/timezone-label";

import DownloadIcon from "../icons/DownloadIcon.astro";

const image: Image = {
  src: buildUrl("/images/about.webp"),
  alt: "Contact me",
};

const hints = ['Contacts', `Serbia, ${getTimezoneLabel()}`];
const title = "Let's get in touch!";
const links = [
  { label: "Telegram", href: "#" },
  { label: "LinkedIn", href: "#" },
  { label: "CV", href: "#", icon: DownloadIcon },
]

const email = "olgabis.design@gmail.com";

---
<div class="contacts">
  <div class="contacts__content">
    <span class="contacts__hints">
      {hints.map((hint, index) => (
        <span key={index}>{hint}</span>
      ))}
    </span>
    <div class="contacts__info">
      <h2>{title}</h2>
      <div class="contacts__list">
        {links.map((link, index) => (
          <div class="contacts__point">
            <span class="contacts__number">( {index + 1} )</span>
            <a href={link.href} class="contacts__plaque">
              {link.icon && <link.icon size="15" class="contacts__link-icon" />}
              {link.label}
            </a>
          </div>
        ))}
      </div>
      <span class="contacts__mail">
        {email}
      </span>
    </div>
  </div>
  <img class="contacts__image" src={image.src} alt={image.alt} loading="lazy" decoding="async" />
</div>

<style lang="scss">
.contacts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: stretch;
  gap: var(--space-4l);
  width: 100%;
  background: var(--color-dark-grey);
  box-sizing: border-box;

  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: 130%;
}

.contacts__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4l);
  min-width: 0;
  padding: var(--space-4l) var(--space-6l) var(--container-padding) var(--space-6l);
}

.contacts__hints {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.contacts__info {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  gap: var(--space-4l);

  h2 {
    font-size: 48px;
    font-style: normal;
    font-weight: 400;
    line-height: 113%;
  }
}

.contacts__list {
  display: flex;
  flex-grow: 1;
  flex-direction: column;
  gap: var(--space-l);

  .contacts__number {
    display: inline-block;
    width: var(--space-4l);
    font-size: var(--space-xl);
    color: var(--color-text);
  }
}

.contacts__plaque {
  display: inline-flex; 
  align-items: center;
  gap: var(--space-xs);
  
  min-width: 104px;
  max-width: 100%;
  padding: var(--space-s) var(--space-xl);
  border: 1px solid rgba(15, 15, 15, 0.7);
  
  color: var(--color-text);
  text-decoration: none;
  white-space: nowrap;
  
  transition: all 0.2s ease-in-out;
  cursor: pointer;

  &:hover {
    background-color: var(--color-accent);
    border-color: var(--color-dark);
  }
}

.contacts__point {
  display: flex;
  align-items: center;
  gap: var(--space-4l);
  min-width: 0;
} 

.contacts__link-icon {
  flex-shrink: 0;
  margin-top: -2px;
}

.contacts__mail {
  display: flex;
  justify-self: flex-end;
  font-size: 36px;
  line-height: 1.13;
  overflow-wrap: anywhere;
}

.contacts__image {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 241 / 200;
  object-fit: cover;
  max-height: 600px;
}

@media (max-width: 1024px) {
  .contacts {
    grid-template-columns: 1fr;
  }

  .contacts__image {
    width: 100%;
    max-height: none;
  }
}

@media (max-width: 767px) {
  .contacts__content,
  .contacts__info {
    gap: var(--space-xl);
  }

  .contacts__hints {
    gap: var(--space-xs);
  }

  .contacts__point {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
    gap: var(--space-m);
  }

  .contacts__mail {
    font-size: 28px;
  }

  .contacts__plaque {
    width: 100%;
    min-width: 0;
    white-space: normal;
  }
}

@media (max-width: 479px) {
  .contacts__content {
    gap: var(--space-l);
  }

  .contacts__info h2 {
    font-size: 36px;
  }

  .contacts__number {
    width: 24px;
    font-size: 16px;
  }

  .contacts__mail {
    font-size: 22px;
    line-height: 1.2;
  }
}
</style>
