---
const items = [
  {
    title: "Software\nfor veterinary clinics",
    desc: "Helps manage appointments, patient records, inpatient treatment workflows, and day-to-day operations.",
    tags: ["Health tech", "User Experience Design (UX)", "Prototyping", "Interaction Design", "User Testing & Feedback"],
    imageLeft: "/portfolio/images/project_nl_left.webp",
    imageRight: "/portfolio/images/project_nl_right.webp",
    href: "/projects/vet/",
  },
  {
    title: "SaaS service is a data-driven\nwebsite optimization",
    desc: "Using tools like heat maps and A/B testing, teams can validate hypotheses.",
    tags: ["SaaS", "User Experience Design (UX)", "Prototyping", "User Interface Design (UI)", "Web design", "3D graphics"],
    imageLeft: "/portfolio/images/project_ab_left.webp",
    imageRight: "/portfolio/images/project_ab_right.webp",
    href: "/projects/saas/",
  },
];
---

<div class="projects-list">
  {items.map((project) => (
    <article class="project-card">
      <div class="project-card__content">
        <div class="project-card__header">
          <h3 class="project-card__heading">{project.title}</h3>
          <p class="project-card__description">{project.desc}</p>
        </div>

        <img
          class="project-card__image"
          src={project.imageLeft}
          alt=""
          loading="lazy"
          decoding="async"
        />

        <div class="project-card__tags" aria-label="Project tags">
          {project.tags.map((tag, index) => (
            <>
              {index > 0 && <span class="project-card__tag-separator" aria-hidden="true"></span>}
              <span class="project-card__tag">{tag}</span>
            </>
          ))}
        </div>

        <a class="project-card__link" href={project.href}>
          see more
        </a>
      </div>

      <figure class="project-card__media">
        <img
          class="project-card__image--lg"
          src={project.imageRight}
          alt=""
          loading="lazy"
          decoding="async"
        />
      </figure>
    </article>
  ))}
</div>

<style lang="scss">
.projects-list {
  display: grid;
  gap: var(--space-4l);
}

/* Card */
.project-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  padding: var(--space-xl);
  display: grid;
  justify-items: center;
  gap: var(--space-xl);
  min-height: 620px;
}

.project-card__content {
  max-width: 560px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-xl);
}

.project-card__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-m);
}

.project-card__heading {
  margin: 0;
  font-weight: var(--font-weight-regular);
  width: var(--card-content-width-max);
  letter-spacing: -0.02em;
  width: 100%;

  font-size: 32px;
  line-height: 1.1;
}

.project-card__description {
  margin: 0;
  font-size: 14px;
  line-height: 1.5;
  max-width: 420px;
}

.project-card__image {
  max-width: var(--card-content-width-min);
}

.project-card__image--lg {
  width: 100%;
}

.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 12px;
  line-height: 1;
  max-width: var(--card-content-width-min);
}

.project-card__tag {
  white-space: nowrap;
}

.project-card__tag-separator {
  width: 4px;
  height: 4px;
  aspect-ratio: 1 / 1;

  border-radius: 50%;
  background: currentColor;

  flex-shrink: 0;
}

.project-card__link {
  margin-top: var(--space-l);
  display: inline-block;

  font-size: 24px;
  line-height: 1.3;
  text-decoration: underline;
  text-decoration-style: solid;
  text-decoration-skip-ink: auto;
  text-decoration-thickness: auto;
  text-underline-offset: auto;
  text-underline-position: from-font;
}

/* Media */
.project-card__media {
  margin: 0;
  height: 100%;
  background: var(--color-background);
  border: 1px solid var(--color-border);
  display: grid;
  place-items: center;
}

.project-card__image {
  width: 100%;
  height: auto;
  display: block;
}

/* Desktop layout like макет: текст слева, изображение справа */
@media (min-width: 900px) {
  .project-card {
    grid-template-columns: 1fr 1.2fr;
    align-items: center;
  }
}

@media (max-width: 479px) {
  .projects-section__title {
    font-size: 34px;
  }

  .project-card__heading {
    font-size: 28px;
  }

  .project-card__media {
    padding: var(--space-xs);
  }
}
</style>