---
// const ctaLabel = "View project";
const ctaLabel = "see more";

const items = [
  {
    title: ["Software", "for veterinary clinics"],
    desc: "Helps manage appointments, patient records, inpatient treatment workflows, and day-to-day operations.",
    tags: ["Health tech", "User Experience Design", "Prototyping", "Interaction Design", "User Testing & Feedback"],
    imageLeft: "/images/project_vet.webp",
    imageRight: "/images/project_vet_info.webp",
    href: "/projects/vet/",
  },
  {
    title: ["SaaS website", "optimization platform"],
    desc: "Using tools like heat maps and A/B testing, teams can validate hypotheses.",
    tags: ["SaaS", "User Experience Design", "Prototyping", "User Interface Design", "Web design", "3D graphics"],
    imageLeft: "/images/project_ab.webp",
    imageRight: "/images/project_ab_heat.webp",
    href: "/projects/saas/",
  },
];
---

<div class="projects-list">
  {items.map((project) => (
    <article class="project-card">
      <div class="project-card__content">
        <div class="project-card__header">
          <h3 class="project-card__heading">
            {project.title.map((line, index) => (
              <>
                {index > 0 && <br />}
                {line}
              </>
            ))}
          </h3>
          <p class="project-card__description">{project.desc}</p>
        </div>

        <img
          class="project-card__image"
          src={project.imageLeft}
          alt=""
          loading="lazy"
          decoding="async"
        />

        <div class="project-card__tags" aria-label="Project tags">
          {project.tags.map((tag, index) => (
            <>
              {index > 0 && <span class="project-card__tag-separator" aria-hidden="true"></span>}
              <span class="project-card__tag">{tag}</span>
            </>
          ))}
        </div>

        <a class="project-card__link" href={project.href}>
          {ctaLabel}
        </a>
      </div>

      <div class="project-card__media">
        <img
          src={project.imageRight}
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    </article>
  ))}
</div>

<style lang="scss">
.projects-list {
  display: grid;
  gap: var(--space-4l);
}

/* Card */
.project-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  padding: var(--space-xl);
  display: grid;
  justify-items: center;
  gap: var(--space-xl);
  min-height: 620px;
}

.project-card__content {
  max-width: var(--width-max);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-xl);
}

.project-card__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-m);
  max-width: 326px;
}

.project-card__heading {
  margin: 0;
  font-weight: var(--font-weight-regular);
  width: var(--card-content-width-max);
  letter-spacing: -0.02em;
  width: 100%;

  font-size: 34px;
  line-height: 1.15;
}

.project-card__description {
  margin: 0;
  font-size: 16px;
  line-height: 1.3;
  max-width: 420px;
}

.project-card__image {
  width: auto;
  max-width: 300px;
}

.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 12px;
  line-height: 1.3;
  max-width: var(--card-content-width-min);
}

.project-card__tag {
  white-space: nowrap;
}

.project-card__tag-separator {
  width: 4px;
  height: 4px;
  aspect-ratio: 1 / 1;

  border-radius: 50%;
  background: currentColor;

  flex-shrink: 0;
}

.project-card__link {
  margin-top: var(--space-l);
  display: inline-block;

  font-size: 24px;
  line-height: 1.3;
  text-transform: lowercase;
  text-decoration: underline;
  text-decoration-style: solid;
  text-decoration-skip-ink: auto;
  text-decoration-thickness: auto;
  text-underline-offset: auto;
  text-underline-position: from-font;
}

.project-card__media {
  margin: 0;
  height: 100%;
  width: 100%;
  background: var(--color-white);
  display: grid;
  place-items: center;
}

/* Desktop layout like макет: текст слева, изображение справа */
@media (min-width: 900px) {
  .project-card {
    grid-template-columns: 1fr 1.2fr;
    align-items: center;
  }
  .project-card__media {
    place-items: stretch;
  }
}

@media (max-width: 768px) {
  .project-card__image {
    max-width: 100%;
  }
}

@media (max-width: 479px) {
  .projects-section__title {
    font-size: 34px;
  }

  .project-card__heading {
    font-size: 28px;
  }

  .project-card__media {
    padding: var(--space-xs);
  }
}
</style>
