---
import SkillChips from "./SkillChips.astro";
import MediaGrid from "../shared/MediaGrid.astro";
import type { Image } from "../../types";

const headline =
  "Senior UX/UI designer shaping digital products from concept to launch. I've collaborated with";

const skills = [
  "strong UX thinking",
  "human-centered design",
  "interactive interfaces",
  "2D & 3D visuals",
  "AI-tools",
];

const heroImages: Record<string, Image> = {
  left: {
    src: "/portfolio/images/ab_mockup.webp",
    alt: "A screenshot of a mobile app interface showcasing a sleek and modern design with intuitive navigation and visually appealing graphics.",
  },
  right: {
    src: "/portfolio/images/vet_mockup.webp",
    alt: "A screenshot of a mobile app interface showcasing a sleek and modern design with intuitive navigation and visually appealing graphics.",
  },
  cursor: {
    src: "/portfolio/images/cursors/cursor.svg",
    alt: "A cursor icon representing user interaction and navigation within a digital interface.",
  },
};
---

<div class="hero">
  <div class="hero__header">
    <h1 class="hero__title" data-node-id="2151:213">
      {headline}{" "}
      <span class="hero__title-accent">leading design studios,</span>{" "}
      <span class="hero__title-accent">international startups,</span>{" "}
      <span class="hero__title-accent">product teams,</span>{" "}
      designing websites and apps
    </h1>
    <div class="hero__skills">
      <SkillChips items={skills} />
    </div>

    <div class="hero__cursor" aria-hidden="true">
      <img
        class="hero__cursor-icon"
        src={heroImages.cursor.src}
        alt={heroImages.cursor.alt}
        loading="eager"
        decoding="async"
      />
    </div>
    <MediaGrid images={Object.values(heroImages).filter((image) => image !== heroImages.cursor)} />
  </div>
</div>

<style lang="scss">
.hero {
  --cursor-motion: 32px;
  gap: 90px;
}

.hero,
.hero__header {
  display: flex;
  flex-direction: column;
}

.hero__header {
  position: relative;
  gap: var(--space-4l);
}

.hero__title {
  margin: 0;
  color: var(--color-text);

  font-family: var(--font-family-base);
  font-style: normal;
  font-weight: var(--font-weight-regular);

  font-size: clamp(34px, 3.54vw, 51px);
  line-height: 1.13;
  letter-spacing: 0;

  max-width: 1020px;
}

.hero__title-accent {
  display: inline-block;
  white-space: nowrap;
  background: var(--color-accent);
  padding: 0.03em 0.16em 0.05em;
}

.hero__cursor {
  position: absolute;

  left: min(calc(980px + var(--space-l)), calc(100% - 140px));
  top: 110px;

  display: inline-flex;
  align-items: center;
  gap: 10px;

  pointer-events: none;

  transform: translate3d(0, 0, 0);

  animation: figma-drift 8s cubic-bezier(0.2, 0.8, 0.2, 1) infinite;
  will-change: transform;
}

.hero__cursor-icon {
  display: block;
  height: auto;
}

@media (prefers-reduced-motion: reduce) {
  .hero__cursor {
    animation: none;
  }
}

/* laptop */
@media (max-width: 1199px) {
  .hero__title {
    font-size: clamp(34px, 4.2vw, 46px);
  }
}

/* tablet */
@media (max-width: 1023px) {
  .hero__title {
    font-size: clamp(34px, 4.2vw, 40px);
  }

  .hero__cursor {
    display: none;
  }
}

/* mobile */
@media (max-width: 767px) {
  .hero__title {
    max-width: 350px;
    font-size: 34px;
    line-height: 1.15;
  }

  .hero__title-accent {
    padding: 0 0.12em 0.02em;
  }
}

/* small mobile */
@media (max-width: 479px) {
  .hero__title {
    font-size: 30px;
    line-height: 1.1;
  }
}
</style>
