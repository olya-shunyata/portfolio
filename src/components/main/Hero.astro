---
import SkillChips from "../shared/SkillChips.astro";
import MediaGrid from "../shared/MediaGrid.astro";
import type { Image } from "../../types";
import { buildUrl } from "../../scripts/path-utils";

const headline = [
  {
    text: "Senior UX/UI designer shaping digital products from concept to launch. I've collaborated with ",
  },
  {
    text: "leading design studios",
    highlight: true,
  },
  {
    text: ", ",
  },
  {
    text: "international startups",
    highlight: true,
  },
  {
    text: ", ",
  },
  {
    text: "product teams",
    highlight: true,
  },
  {
    text: " designing websites and apps.",
  }
]

const skills = [
  "strong UX thinking",
  "human-centered design",
  "interactive interfaces",
  "2D & 3D visuals",
  "AI-tools",
];

// const skills = [
//   "Complex user flows",
//   "End-to-end UX/UI",
//   "Design systems",
//   "Visual direction",
//   "Interaction design",
// ];

const heroImages: Record<string, Image> = {
  left: {
    src: buildUrl("/images/ab_mockup.webp"),
    alt: "A screenshot of a mobile app interface showcasing a sleek and modern design with intuitive navigation and visually appealing graphics.",
  },
  right: {
    src: buildUrl("/images/vet_mockup.webp"),
    alt: "A screenshot of a mobile app interface showcasing a sleek and modern design with intuitive navigation and visually appealing graphics.",
  },
  cursor: {
    src: buildUrl("/images/cursors/cursor.svg"),
    alt: "A cursor icon representing user interaction and navigation within a digital interface.",
  },
};
---

<div class="hero">
  <div class="hero__header">
    <h1 class="hero__title">
      {headline.map((item) =>
        item?.highlight ? <span class="hero__title-accent">{item.text}</span> : item.text
      )}
    </h1>
    <div class="hero__skills">
      <SkillChips items={skills} />
    </div>

    <div class="hero__cursor" aria-hidden="true">
      <img
        class="hero__cursor-icon"
        src={heroImages.cursor.src}
        alt={heroImages.cursor.alt}
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
  <MediaGrid images={Object.values(heroImages).filter((image) => image !== heroImages.cursor)} />
</div>

<style lang="scss">
.hero {
  --cursor-motion: 32px;
  --hero-gap: 70px;
  gap: var(--hero-gap);
}

.hero,
.hero__header {
  display: flex;
  flex-direction: column;
}

.hero__header {
  position: relative;
  gap: 35px;
}

.hero__title {
  margin: 0;
  color: var(--color-text);

  font-family: var(--font-family-base);
  font-style: normal;
  font-weight: var(--font-weight-regular);

  font-size: clamp(34px, 3.54vw, 51px);
  line-height: 1.13;
  letter-spacing: 0;

  max-width: 1020px;
}

.hero__title-accent {
  display: inline-block;
  white-space: nowrap;
  background: var(--color-accent);
  padding: 0.03em 0.16em 0.05em;
}

.hero__cursor {
  position: absolute;

  left: min(calc(980px + var(--space-6l)), calc(100% - 100px));
  top: clamp(25vh, 120px, 300px);

  display: inline-flex;
  align-items: center;
  gap: 10px;

  pointer-events: none;

  transform: translate3d(0, 0, 0);

  animation: figma-drift 8s cubic-bezier(0.2, 0.8, 0.2, 1) infinite;
  will-change: transform;
}

.hero__cursor-icon {
  display: block;
  height: auto;
}

@media (prefers-reduced-motion: reduce) {
  .hero__cursor {
    animation: none;
  }
}

/* laptop */
@media (max-width: 1199px) {
  .hero__title {
    font-size: clamp(34px, 4.2vw, 46px);
  }
}

/* tablet */
@media (max-width: 1023px) {
  .hero__title {
    font-size: clamp(34px, 4.2vw, 40px);
  }

  .hero__cursor {
    display: none;
  }
}

/* mobile */
@media (max-width: 767px) {
  .hero__title {
    max-width: 350px;
    font-size: 34px;
    line-height: 1.15;
  }

  .hero__title-accent {
    padding: 0 0.12em 0.02em;
  }
}

/* small mobile */
@media (max-width: 479px) {
  .hero__title {
    font-size: 30px;
    line-height: 1.1;
  }
}
</style>
