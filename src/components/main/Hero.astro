---
import SkillChips from "./SkillChips.astro";
import type { Image } from "../../types";

const headline =
  "Senior UX/UI designer shaping digital products from concept to launch. I’ve collaborated with leading design studios, international startups, product teams, designing websites and apps";

const skills = [
  "strong UX thinking",
  "human-centered design",
  "interactive interfaces",
  "2D & 3D visuals",
  "AI-tools",
];

const heroImages: Record<string, Image> = {
  left: {
    src: "/portfolio/images/hero_01.webp",
    alt: "A screenshot of a mobile app interface showcasing a sleek and modern design with intuitive navigation and visually appealing graphics.",
  },
  right: {
    src: "/portfolio/images/hero_02.webp",
    alt: "A screenshot of a mobile app interface showcasing a sleek and modern design with intuitive navigation and visually appealing graphics.",
  },
  cursor: {
    src: "/portfolio/images/cursors/cursor.svg",
    alt: "A cursor icon representing user interaction and navigation within a digital interface.",
  },
};
---

<section class="hero-section">
  <div class="container hero-section__container">
    <div class="hero-section__header">
      <h1 class="hero-section__title">{headline}</h1>

      <div class="hero-section__cursor" aria-hidden="true">
        <img
          class="hero-section__cursor-icon"
          src={heroImages.cursor.src}
          alt={heroImages.cursor.alt}
          loading="eager"
          decoding="async"
        />
      </div>

      <div class="hero-section__skills">
        <SkillChips items={skills} />
      </div>
      
    </div>
    <div class="hero-section__media-grid">
    {Object.values(heroImages).filter((image) => image !== heroImages.cursor).map((image) => (
      <figure class="hero-section__media-card">
        <img
          class="hero-section__media-image"
          src={image.src}
          alt={image.alt}
          loading="eager"
          decoding="async"
        />
      </figure>
    ))}
    </div>
  </div>
</section>

<style lang="scss">

.hero-section {
  --cursor-motion: 32px;
}

.hero-section__container,
.hero-section__header {
  display: flex;
  flex-direction: column;
}

.hero-section__container {
  gap: 90px;
}

.hero-section__header {
  position: relative;
  gap: var(--space-4l);
}

.hero-section__title {
  color: var(--color-text);

  font-family: var(--font-family-base);
  font-style: normal;
  font-weight: var(--font-weight-regular);

  font-size: 52px;
  line-height: 1.2;
  letter-spacing: -0.02em;

  max-width: 980px;
}

.hero-section__cursor {
  position: absolute;

  left: min(calc(980px + var(--space-l)), calc(100% - 140px));
  top: 110px;

  display: inline-flex;
  align-items: center;
  gap: 10px;

  pointer-events: none;

  transform: translate3d(0, 0, 0);

  animation: figma-drift 8s cubic-bezier(0.2, 0.8, 0.2, 1) infinite;
  will-change: transform;
}

.hero-section__cursor-icon {
  display: block;
  height: auto;
}

.hero-section__media-grid {
  display: grid;
  gap: var(--space-m);
  grid-template-columns: repeat(2, 1fr);
}

.hero-section__media-card {
  margin: 0;
}

@media (prefers-reduced-motion: reduce) {
  .hero-section__cursor {
    animation: none;
  }
}

/* laptop */
@media (max-width: 1199px) {
  .hero-section__title {
    font-size: 46px;
  }
}

/* tablet */
@media (max-width: 1023px) {
  .hero-section__title {
    font-size: 40px;
  }

  .hero-section__cursor {
    display: none;
  }

  .hero-section__media-grid {
    grid-template-columns: 1fr;
  }
}

/* mobile */
@media (max-width: 767px) {
  .hero-section__title {
    font-size: 34px;
    line-height: 1.15;
  }
}

/* small mobile */
@media (max-width: 479px) {
  .hero-section__title {
    font-size: 30px;
    line-height: 1.1;
  }
}
</style>