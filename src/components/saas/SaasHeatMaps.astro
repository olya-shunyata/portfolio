---
import SubHeader from "../shared/SubHeader.astro"
import type { Image } from '../../types';
import { buildUrl } from "../../scripts/path-utils";

const header = {
    title: "( Heatmaps )",
}

const images: Image[] = Array.from({ length: 3 }, (_, index) => ({
  src: buildUrl(`/images/saas/heatmaps/hm_${index + 1}.webp`),
  alt: `Heatmap image ${index + 1}.`,
}));

---

<div class="saas-heatmaps">
    <div class="grid-layout">
        <SubHeader item={header} type="h3" />
    </div>
    <div class="saas-heatmaps__images">
        {images.map((image) => 
            <img class="saas-heatmaps__image" src={image.src} alt={image.alt} />
        )}
    </div>
</div>

<style lang="scss">

.saas-heatmaps {
    display: flex;
    flex-direction: column;
    gap: 40px;
}

.saas-heatmaps__images {
    display: flex;
    flex-direction: column;
    gap: 50px;
    padding: 90px;
    background: var(--color-dark);
}

.saas-heatmaps__image {
    margin: auto;
}

@media (max-width: 1024px) {
    .saas-heatmaps {
        gap: 32px;
    }
    .saas-heatmaps__images {
        gap: 20px;
        padding: 50px 20px;
    }
}

@media (max-width: 475px) {
    .saas-heatmaps__images {
        padding: 28px 12px;
    }
}
</style>
