---
import "../styles/reset.scss";
import "../styles/fonts.scss";
import "../styles/ui-kit.scss";
import "../styles/mixins.scss";
import "../styles/animations.scss";
import { buildUrl } from "../scripts/path-utils";
import { DEFAULT_OG_IMAGE_PATH, PERSON_IMAGE_PATH, LINKEDIN_URL, TG_URL } from "../constants";
import { content } from "../content";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImagePath?: string;
  ogImageAlt?: string;
  ogType?: "website" | "profile" | "article";
  robots?: string;
};

const basePath = `${import.meta.env.BASE_URL}`.replace(/\/$/, "");
const siteUrl = import.meta.env.SITE;
const defaultCanonicalPath = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || "/"
  : Astro.url.pathname || "/";

const {
  title = content.shared.brand.name,
  description = content.shared.meta.defaultDescription,
  canonicalPath = defaultCanonicalPath,
  ogTitle = title,
  ogDescription = description,
  ogImagePath = DEFAULT_OG_IMAGE_PATH,
  ogImageAlt = content.shared.meta.ogAlt,
  ogType = "website",
  robots = "index,follow",
} = Astro.props as Props;

const toAbsoluteUrl = (path: string) => new URL(buildUrl(path), siteUrl).toString();
const canonicalUrl = toAbsoluteUrl(canonicalPath);
const ogImageUrl = toAbsoluteUrl(ogImagePath);
const personImageUrl = toAbsoluteUrl(PERSON_IMAGE_PATH);

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: content.shared.brand.name,
  jobTitle: "Senior UX/UI Designer",
  description: content.shared.meta.defaultDescription,
  url: canonicalUrl,
  image: personImageUrl,
  email: `mailto:${content.shared.contacts.email}`,
  sameAs: [LINKEDIN_URL, TG_URL],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Belgrade",
    addressCountry: "Serbia",
  },
  homeLocation: {
    "@type": "Place",
    name: content.shared.location.cityCountry,
  },
  knowsLanguage: ["English", "Russian"],
  knowsAbout: content.shared.meta.knowsAbout,
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content={content.shared.brand.name} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={buildUrl("/favicon/favicon.ico?v=20260413")} sizes="any" />
    <link rel="icon" href={buildUrl("/favicon/favicon-32x32.png?v=20260413")} type="image/png" sizes="32x32" />
    <link rel="icon" href={buildUrl("/favicon/favicon-16x16.png?v=20260413")} type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href={buildUrl("/favicon/apple-touch-icon.png?v=20260413")} sizes="180x180" />
    <link rel="manifest" href={buildUrl("/favicon/site.webmanifest?v=20260413")} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={content.shared.brand.name} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link
      rel="preload"
      href={buildUrl("/fonts/pp-neue-montreal/ppneuemontreal-book.woff")}
      as="font"
      type="font/woff"
      crossorigin
    />

    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
  </head>
  <body>
    <slot />
  </body>
</html>
