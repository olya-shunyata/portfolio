---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/main/Header.astro";
import Hero from "../components/main/Hero.astro";
import Projects from "../components/main/Projects.astro";
import ProjectComponent from "../components/shared/ProjectComponent.astro";
import Confidential from "../components/main/Confidential.astro";
import ShowReel from "../components/main/ShowReel.astro";
import Contacts from "../components/main/Contacts.astro";
import Footer from "../components/main/Footer.astro";
---
<BaseLayout title="Olga Bis — Portfolio">
  <Header />
  <main>
    <Hero />
    <ProjectComponent title="Projects" mobileFluid>
      <Projects />
    </ProjectComponent>
    <ProjectComponent title="Confidential" delimiter mobileFluid>
      <Confidential />
    </ProjectComponent>
    <ProjectComponent title="What else I can do" mobileFluid>
      <ShowReel />
    </ProjectComponent>
  </main>
  <Footer />
</BaseLayout>
<style lang="scss">
main {
  display: flex;
  flex-direction: column;
  gap: 90px;
}
</style>
